---
layout: base.njk
title: Dialog Lab
description: Be heard
---
<div class="w-full flex flex-col items-center text-center">

  <!-- Hero -->
  <section id="home" class="snap-start scroll-mt-[92px] md:scroll-mt-[76px] w-full min-h-screen bg-white flex flex-col md:flex-row items-center justify-center gap-8 md:gap-4 px-6 sm:px-10 md:px-16 pt-28 md:pt-24 pb-12">
    <div class="flex flex-col items-center md:items-start text-center md:text-left gap-5 md:gap-8 w-full md:w-1/2 max-w-[32rem] md:max-w-[36rem]">
      <h1 class="text-[1.75em] sm:text-[2.25em] md:text-[3em] leading-tight font-bold">
        The <em class="italic">easiest</em> way to have a <em class="italic">civil</em> chat with someone on the other side.
      </h1>
    </div>

    <div class="w-full md:w-1/2 flex items-center justify-center">
      <div class="w-48 sm:w-64 md:w-full md:max-w-md">
        <img src="{{ '/assets/images/DL-Mark-Stacked.svg' | url }}" alt="" class="w-full h-full object-contain" />
      </div>
    </div>
  </section>

  <!-- Why Dialog Lab -->
  <section id="why-dialog-lab" class="snap-start scroll-mt-[92px] md:scroll-mt-[76px] w-full max-w-[720px] mx-auto flex flex-col items-center justify-start gap-4 md:gap-5 px-4 sm:px-6 md:px-8 pt-16 pb-12 text-center">
    <h3 class="w-full text-[1.375em] md:text-[1.75em] leading-snug">Why Dialog Lab</h3>

    <div class="flex flex-col items-center gap-3 w-full text-center">
      <p class="text-[1em] md:text-[1.25em] leading-snug">
        We're living in a tense world, and it's easier to stay in our bubble than talk to someone who sees things differently.
      </p>
      <p class="text-[1em] md:text-[1.25em] leading-snug">
        Dialog Lab makes it easy to have a real, civil conversation with someone on the other side. A simple chat can lead to mutual understanding and reduce feelings of anger and mistrust.
      </p>
    </div>
  </section>

  <!-- How the App Works: Step 1 -->
  <section id="how-it-works" class="snap-start scroll-mt-[92px] md:scroll-mt-[76px] w-full flex flex-col items-center justify-start gap-4 md:gap-6 px-4 sm:px-6 md:px-8 pt-16 pb-12">
    <h3 class="max-w-[30rem] text-[1.375em] md:text-[1.75em] leading-snug">How the App Works</h3>

    <div class="flex flex-col items-center w-full">
      <p class="max-w-[41.375rem] text-[1em] md:text-[1.5em] leading-snug mb-[calc(16pt+1.5rem)]">
        1. Choose your position on the topics that are important to you.
      </p>

      <div
        x-data="{
          images: [
            'https://i.imgur.com/oBphgtZ.png',
            'https://i.imgur.com/OU4ULIO.png',
            'https://i.imgur.com/IQgUy4y.png',
            'https://i.imgur.com/VuOCkEq.png',
            'https://i.imgur.com/PiiRnPT.png',
            'https://i.imgur.com/HaYHho1.png',
            'https://i.imgur.com/3wYfEFj.png',
          ],
          current: 0,
          init() {
            setInterval(() => {
              this.current = (this.current + 1) % this.images.length;
            }, 3400);
          }
        }"
        class="relative w-full max-w-sm lg:max-w-xl aspect-[12/7] overflow-hidden rounded-2xl"
      >
        <template x-for="(img, i) in images" :key="i">
          <img
            :src="img"
            alt=""
            decoding="async"
            x-show="i === current"
            x-transition:enter="transition ease-out duration-500"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-300"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="slideshow-img absolute inset-0 w-full h-full object-contain"
          />
        </template>

        <div class="absolute -bottom-6 inset-x-0 flex justify-center gap-1.5">
          <template x-for="(img, i) in images" :key="i">
            <span
              class="w-1.5 h-1.5 rounded-full transition-colors duration-300"
              :class="i === current ? 'bg-brand' : 'bg-brand/25'"
            ></span>
          </template>
        </div>
      </div>
    </div>
  </section>

  <!-- How the App Works: Step 2 -->
  <section id="how-it-works-step-2" class="snap-start scroll-mt-[92px] md:scroll-mt-[76px] w-full flex flex-col items-center justify-start gap-4 md:gap-6 px-4 sm:px-6 md:px-8 pt-16 pb-12">

    <div class="flex flex-col items-center w-full">
      <p class="max-w-[41.375rem] text-[1em] md:text-[1.5em] leading-snug mb-[16pt]">
        2. We quickly match you with someone on the other side for a messaging chat. To keep things civil and constructive we use AI to moderate.
      </p>

      <div
        x-data="{
          rows: [
            { side: 'left',  name: null,           text: 'I love cake best. Why did you choose pie?' },
            { side: 'right', name: null,           text: 'Cake is mostly air. Pie is superior.' },
            { side: 'left',  name: null,           text: 'You must be crazy to believe that!' },
            { side: 'left',  name: 'AI Moderator', text: `Let's focus on the idea rather than the person. What part of their argument do you disagree with?` },
          ],
          shown: 0,
          cycle() {
            if (this.shown < this.rows.length) {
              this.shown++;
              setTimeout(() => this.cycle(), this.shown < this.rows.length ? 1500 : 5000);
            } else {
              this.shown = 0;
              setTimeout(() => this.cycle(), 1200);
            }
          },
          isLastInRun(i) {
            const next = this.rows[i + 1];
            return !next || next.side !== this.rows[i].side || next.name;
          },
          init() { this.cycle(); }
        }"
        class="flex flex-col justify-start gap-3 lg:gap-[1.125rem] w-full max-w-sm lg:max-w-xl h-[calc(14rem+100pt)] lg:h-[calc(21rem+100pt)] shrink-0 overflow-hidden text-left font-system"
      >
        <template x-for="(row, i) in rows" :key="i">
          <div
            class="flex flex-col w-full"
            :class="row.side === 'right' ? 'items-end' : 'items-start'"
            x-show="i < shown"
            x-transition:enter="transition ease-out duration-600"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
          >
            <span x-show="row.name" x-text="row.name" class="text-[13px] lg:text-[19.5px] font-semibold text-indigo-600 mb-1"></span>
            <div
              class="relative px-3.5 py-2.5 lg:px-5 lg:py-4 text-[16px] lg:text-2xl leading-snug break-words shadow-sm"
              :class="{
                'max-w-[75%] rounded-2xl bg-gradient-to-b from-sky-100 to-sky-200 text-neutral-900': row.side === 'left' && !row.name,
                'max-w-[75%] rounded-2xl bg-gradient-to-b from-neutral-200 to-neutral-300 text-neutral-900': row.side === 'right' && !row.name,
                'chat-bubble-tail chat-bubble-tail-left': row.side === 'left' && !row.name && isLastInRun(i),
                'chat-bubble-tail chat-bubble-tail-right': row.side === 'right' && !row.name && isLastInRun(i),
                'max-w-full w-full rounded-xl bg-gradient-to-br from-indigo-100 to-indigo-200 text-neutral-900': row.name,
              }"
              x-text="row.text"
            ></div>
          </div>
        </template>
      </div>
    </div>
  </section>

  <!-- AI Moderation Principles -->
  <section id="ai-moderation-principles" class="snap-start scroll-mt-[92px] md:scroll-mt-[76px] w-full flex flex-col items-center justify-start gap-4 md:gap-5 px-4 sm:px-6 md:px-8 pt-16 pb-12">
    <h3 class="max-w-[30rem] text-[1.375em] md:text-[1.75em] leading-snug">AI Moderation Principles</h3>

    <div class="flex flex-col items-start gap-3 max-w-[30rem] w-full text-left">
      <ul class="flex flex-col gap-3 text-[1em] md:text-[1.25em] leading-snug list-disc pl-5">
        <li>Must serve the users by enforcing and facilitating civil conversation</li>
        <li>Must be direct and transparent in communication</li>
        <li>Must be unbiased and never take a side</li>
        <li>Must never try to persuade</li>
      </ul>
    </div>
  </section>

  <!-- Mission + signup -->
  <section id="join-beta" class="snap-start scroll-mt-[92px] md:scroll-mt-[76px] w-full flex flex-col items-center gap-4 md:gap-6 px-4 sm:px-6 md:px-8 pt-16 pb-12">
  <div class="flex flex-col items-start gap-1 max-w-[30rem] w-full text-left">
    <h3 class="text-[1.375em] md:text-[1.75em] leading-snug text-center w-full">Join the Beta Test</h3>
    <p class="text-[1em] md:text-[1.25em] leading-snug mt-3">
      We're recruiting a select group to be included in our beta app testing program. To be considered, you must be open to civil conversations via messaging with people who see things differently.
    </p>
    <p class="text-[1em] md:text-[1.25em] leading-snug mt-3">
      Users will be anonymous to eachother and all information will be held confidential.
    </p>

    <form
      x-data="{
        status: 'idle',
        errorMessage: '',
        async submit(event) {
          this.status = 'loading';
          this.errorMessage = '';
          const form = event.target;
          try {
            const res = await fetch(form.action, {
              method: 'POST',
              body: new FormData(form),
              headers: { Accept: 'application/json' },
            });
            if (res.ok) {
              this.status = 'success';
              form.reset();
            } else {
              const json = await res.json().catch(() => null);
              this.errorMessage = json && json.errors
                ? json.errors.map(e => e.message).join(', ')
                : 'Something went wrong. Please try again.';
              this.status = 'error';
            }
          } catch (e) {
            this.errorMessage = 'Something went wrong. Please check your connection and try again.';
            this.status = 'error';
          }
        }
      }"
      action="https://formspree.io/f/xdarwboa"
      method="POST"
      @submit.prevent="submit($event)"
      class="w-full flex flex-col gap-3.5 mt-5"
    >
      <template x-if="status === 'success'">
        <p class="text-[1.25em] leading-snug text-green-700">
          Thank you for applying to join the beta. Please share this link with others that may be interested: joindialoglab.com
        </p>
      </template>

      <template x-if="status !== 'success'">
        <div class="flex flex-col gap-3.5">
          <input type="text" name="name" placeholder="Name" maxlength="128" required
            class="h-11 px-4 border border-brand placeholder-brand/55 outline-none text-[1em] md:text-[1.25em]" />

          <input type="email" name="email" placeholder="Email" maxlength="128" required
            class="h-11 px-4 border border-brand placeholder-brand/55 outline-none text-[1em] md:text-[1.25em]" />

          <textarea name="message" placeholder="What are you hoping to get out of joining?" maxlength="16384" required
            class="h-40 p-4 border border-brand placeholder-brand/55 outline-none text-[1em] md:text-[1.25em] leading-snug"></textarea>

          <div class="flex items-center gap-4">
            <input type="checkbox" name="consent" value="checked" required id="consent"
              class="w-6 h-6 border border-brand accent-brand shrink-0" />
            <label for="consent" class="text-[1em] md:text-[1.25em] leading-snug text-brand-dark">
              I certify that I am 18 years or older.
            </label>
          </div>

          <template x-if="status === 'error'">
            <p class="text-red-600 text-[1em]" x-text="errorMessage"></p>
          </template>

          <div>
            <button type="submit" :disabled="status === 'loading'"
              class="h-10 px-5 rounded-full bg-brand text-white text-[1.125em] md:text-[1.5em] disabled:opacity-35 disabled:cursor-default">
              <span x-show="status !== 'loading'">Submit</span>
              <span x-show="status === 'loading'">Sending…</span>
            </button>
          </div>
        </div>
      </template>
    </form>
  </div>

    <!-- Footer -->
    <div class="flex flex-col items-center gap-2 mt-[38px] mb-[38px]">
      <img src="{{ '/assets/images/DL-Mark-Stacked.svg' | url }}" alt="" class="w-[7.25rem]" />
      <p class="text-[0.875em]">2026</p>
      <a href="mailto:spencer@spencerfrank.com" class="text-[0.875em] hover:underline">Questions?</a>
      <a href="https://www.youtube.com/watch?v=QmSXMpqlVIo" target="_blank" rel="noopener" aria-label="Watch on YouTube" class="mt-1 text-brand/70 hover:text-brand transition-colors">
        <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814ZM9.545 15.568V8.432L15.818 12l-6.273 3.568Z"/>
        </svg>
      </a>
    </div>
  </section>

</div>
