---
layout: base-new.njk
title: Dialog Lab
description: Be heard
---

<section id="what" class="page-new__anchor page-new__anchor--what" aria-label="What">
  <div class="page-new__hero">
    <h1 class="page-new__hero-headline">
      Talk to someone on the other side, and <em>let your guard down</em>.
    </h1>

    <div
      class="page-new__hero-previews"
      x-data="{
        slides: [
          { image: '{{ '/assets/images/hero-mockup-topics.png' | url }}', caption: 'Pick a topic you care about' },
          { image: '{{ '/assets/images/hero-mockup-match.png' | url }}', caption: 'Match with someone who sees it differently' },
          { image: '{{ '/assets/images/hero-mockup-chat.png' | url }}', caption: 'Speak freely. An AI mediator defuses tension before it builds' },
        ],
        current: 0,
        dragging: false,
        dragStartX: 0,
        dragPointerId: null,
        goTo(index) {
          this.current = index;
        },
        next() {
          this.current = (this.current + 1) % this.slides.length;
        },
        prev() {
          this.current = (this.current - 1 + this.slides.length) % this.slides.length;
        },
        onDragStart(e) {
          if (window.matchMedia('(min-width: 768px)').matches) return;
          if (e.pointerType === 'mouse' && e.button !== 0) return;
          this.dragging = true;
          this.dragStartX = e.clientX;
          this.dragPointerId = e.pointerId;
          e.currentTarget.setPointerCapture(e.pointerId);
        },
        onDragEnd(e) {
          if (!this.dragging || e.pointerId !== this.dragPointerId) return;
          this.dragging = false;
          const delta = e.clientX - this.dragStartX;
          this.dragPointerId = null;
          try { e.currentTarget.releasePointerCapture(e.pointerId); } catch (_) {}
          if (Math.abs(delta) < 40) return;
          if (delta < 0) this.next();
          else this.prev();
        },
        onDragCancel(e) {
          if (e.pointerId !== this.dragPointerId) return;
          this.dragging = false;
          this.dragPointerId = null;
          try { e.currentTarget.releasePointerCapture(e.pointerId); } catch (_) {}
        }
      }"
    >
      <div
        class="page-new__hero-viewport"
        :class="{ 'is-dragging': dragging }"
        @pointerdown="onDragStart($event)"
        @pointerup="onDragEnd($event)"
        @pointercancel="onDragCancel($event)"
      >
        <div class="page-new__hero-track" :class="{ 'is-dragging': dragging }" :style="`--hero-index: ${current}`">
          <template x-for="(slide, index) in slides" :key="index">
            <figure class="page-new__hero-slide">
              <div class="page-new__hero-mockup">
                <img
                  :src="slide.image"
                  alt=""
                  width="327"
                  height="674"
                  decoding="async"
                  class="page-new__hero-mockup-img"
                />
              </div>
              <figcaption class="page-new__hero-caption">
                <span class="page-new__hero-caption-num" x-text="`${index + 1}.`"></span>
                <span x-text="slide.caption"></span>
              </figcaption>
            </figure>
          </template>
        </div>
      </div>

      <div class="page-new__hero-pagination" role="tablist" aria-label="App preview screens">
        <template x-for="(slide, index) in slides" :key="index">
          <button
            type="button"
            class="page-new__hero-dot"
            :class="{ 'is-active': current === index }"
            :aria-selected="current === index"
            :aria-label="`Screen ${index + 1}: ${slide.caption}`"
            role="tab"
            @click="goTo(index)"
          ></button>
        </template>
      </div>
    </div>
  </div>
</section>

<section id="why" class="page-new__anchor page-new__anchor--why" aria-label="Why">
  <div class="page-new__why">
    <div class="page-new__why-card">
      <div class="page-new__why-content">
        <h2 class="page-new__why-title">Meet your mediator</h2>

        <div class="page-new__why-prose">
          <p>
            Effective mediation takes both trust and skill. Our AI mediator:
          </p>
        </div>

        <ol class="page-new__why-list">
          <li>Never takes a side — it referees <em>how</em> you argue, not <em>what</em> you believe</li>
          <li>Blocks abusive messages before they're ever sent, so they never touch the conversation</li>
          <li>When it steps in (a nudge, a flag, a suggested rephrase), you both see it and why</li>
          <li>Makes sure you both get your turn</li>
        </ol>
      </div>
    </div>
  </div>
</section>

<section id="founder-note" class="page-new__anchor page-new__anchor--why" aria-label="Founder note">
  <div class="page-new__why">
    <div class="page-new__why-card">
      <div class="page-new__why-content">
        <h2 class="page-new__why-title">I went looking for someone on the other side</h2>

        <div class="page-new__why-prose">
          <p>
            In the wake of political violence, I wanted to find someone to have a heart-to-heart with, hoping we could get past the labels and see each other as fellow citizens who want what's best for the country.
          </p>
          <p>
            That conversation took me almost a year to find. Not because people wouldn't talk, but because we're all operating with our guard up, and it has made talking about politics really suck.
          </p>
          <p>
            I built Dialog Lab so no one has to go looking. It matches you with someone on the other side in seconds, and the conversation that follows is one where you'll actually be heard.
          </p>
          <p>
            Polarization is the problem of our time, and this is my crack at it. I hope you'll join us.
          </p>
          <p class="page-new__why-signature">— Spencer Frank, founder</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="join-beta" class="page-new__anchor page-new__anchor--join" aria-label="Join the beta">
  <div class="page-new__signup">
    <div class="page-new__signup-intro">
      <h2 class="page-new__signup-headline">
        It's just a conversation. <em>We've handled the hard part</em>.
      </h2>

      <div class="page-new__signup-prose">
        <p>
          We're inviting a small group into our beta, and we are recruiting curious people who are willing to hear out someone who sees things differently.
        </p>
        <p>
          You'll be anonymous to the people you talk with, and everything you share with us stays private.
        </p>
      </div>
    </div>

    <div class="page-new__signup-form-wrap">
      <div class="page-new__signup-card">
        <form
          class="page-new__signup-form"
          x-data="{
            status: 'idle',
            errorMessage: '',
            async submit(event) {
              this.status = 'loading';
              this.errorMessage = '';
              const form = event.target;
              try {
                const res = await fetch(form.action, {
                  method: 'POST',
                  body: new FormData(form),
                  headers: { Accept: 'application/json' },
                });
                if (res.ok) {
                  this.status = 'success';
                  form.reset();
                } else {
                  const json = await res.json().catch(() => null);
                  this.errorMessage = json && json.errors
                    ? json.errors.map(e => e.message).join(', ')
                    : 'Something went wrong. Please try again.';
                  this.status = 'error';
                }
              } catch (e) {
                this.errorMessage = 'Something went wrong. Please check your connection and try again.';
                this.status = 'error';
              }
            }
          }"
          action="https://formspree.io/f/xdarwboa"
          method="POST"
          @submit.prevent="submit($event)"
        >
          <template x-if="status === 'success'">
            <p class="page-new__signup-message page-new__signup-message--success">
              Thank you for applying to join the beta. Please share this link with others that may be interested: joindialoglab.com
            </p>
          </template>

          <template x-if="status !== 'success'">
            <div class="page-new__signup-fields">
              <div class="page-new__signup-field">
                <label class="page-new__signup-label" for="signup-name">Your Name</label>
                <input
                  id="signup-name"
                  class="page-new__signup-input"
                  type="text"
                  name="name"
                  maxlength="128"
                  required
                  autocomplete="name"
                />
              </div>

              <div class="page-new__signup-field">
                <label class="page-new__signup-label" for="signup-email">Your Email</label>
                <input
                  id="signup-email"
                  class="page-new__signup-input"
                  type="email"
                  name="email"
                  maxlength="128"
                  required
                  autocomplete="email"
                />
              </div>

              <div class="page-new__signup-field">
                <label class="page-new__signup-label" for="signup-message">What you hope to get out of Dialog Lab</label>
                <textarea
                  id="signup-message"
                  class="page-new__signup-textarea"
                  name="message"
                  maxlength="16384"
                  required
                ></textarea>
              </div>

              <div class="page-new__signup-consent">
                <input
                  id="signup-consent"
                  class="page-new__signup-checkbox"
                  type="checkbox"
                  name="consent"
                  value="checked"
                  required
                />
                <label class="page-new__signup-consent-label" for="signup-consent">
                  I certify that I am 18 years or older.
                </label>
              </div>

              <template x-if="status === 'error'">
                <p class="page-new__signup-message page-new__signup-message--error" x-text="errorMessage"></p>
              </template>

              <div class="page-new__signup-submit-wrap">
                <button class="page-new__signup-submit" type="submit" :disabled="status === 'loading'">
                  <span x-show="status !== 'loading'">Join iOS Beta</span>
                  <span x-show="status === 'loading'">Sending…</span>
                </button>
              </div>
            </div>
          </template>
        </form>
      </div>
    </div>
  </div>

  <footer class="page-new__footer">
    <div class="page-new__footer-brand">
      <img
        class="page-new__footer-mark"
        src="{{ '/assets/images/footer-mark.svg' | url }}"
        alt=""
        width="126"
        height="101"
        decoding="async"
      />
      <p class="page-new__footer-wordmark">Dialog Lab</p>
    </div>
    <div class="page-new__footer-links">
      <p class="page-new__footer-year">2026</p>
      <a href="mailto:spencer@spencerfrank.com" class="page-new__footer-link">Questions?</a>
      <a
        href="https://www.youtube.com/watch?v=QmSXMpqlVIo"
        target="_blank"
        rel="noopener"
        aria-label="Watch on YouTube"
        class="page-new__footer-youtube"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814ZM9.545 15.568V8.432L15.818 12l-6.273 3.568Z"/>
        </svg>
      </a>
    </div>
  </footer>
</section>
