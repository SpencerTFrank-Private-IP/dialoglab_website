---
layout: base-new.njk
title: Dialog Lab
description: Be heard
permalink: /index-new/
---

<section id="what" class="page-new__anchor page-new__anchor--what" aria-label="What">
  <div class="page-new__hero">
    <h1 class="page-new__hero-headline">
      Finally, there is a <em>safe</em> place to explore tough issues.
    </h1>

    <div
      class="page-new__hero-previews"
      x-data="{
        slides: [
          { image: '{{ '/assets/images/hero-mockup-topics.png' | url }}', caption: 'Pick some current topics' },
          { image: '{{ '/assets/images/hero-mockup-match.png' | url }}', caption: 'Get matched like a game' },
          { image: '{{ '/assets/images/hero-mockup-chat.png' | url }}', caption: 'Discuss topics safely' },
        ],
        current: 0,
        dragging: false,
        dragStartX: 0,
        dragPointerId: null,
        goTo(index) {
          this.current = index;
        },
        next() {
          this.current = (this.current + 1) % this.slides.length;
        },
        prev() {
          this.current = (this.current - 1 + this.slides.length) % this.slides.length;
        },
        onDragStart(e) {
          if (window.matchMedia('(min-width: 768px)').matches) return;
          if (e.pointerType === 'mouse' && e.button !== 0) return;
          this.dragging = true;
          this.dragStartX = e.clientX;
          this.dragPointerId = e.pointerId;
          e.currentTarget.setPointerCapture(e.pointerId);
        },
        onDragEnd(e) {
          if (!this.dragging || e.pointerId !== this.dragPointerId) return;
          this.dragging = false;
          const delta = e.clientX - this.dragStartX;
          this.dragPointerId = null;
          try { e.currentTarget.releasePointerCapture(e.pointerId); } catch (_) {}
          if (Math.abs(delta) < 40) return;
          if (delta < 0) this.next();
          else this.prev();
        },
        onDragCancel(e) {
          if (e.pointerId !== this.dragPointerId) return;
          this.dragging = false;
          this.dragPointerId = null;
          try { e.currentTarget.releasePointerCapture(e.pointerId); } catch (_) {}
        }
      }"
    >
      <div
        class="page-new__hero-viewport"
        :class="{ 'is-dragging': dragging }"
        @pointerdown="onDragStart($event)"
        @pointerup="onDragEnd($event)"
        @pointercancel="onDragCancel($event)"
      >
        <div class="page-new__hero-track" :class="{ 'is-dragging': dragging }" :style="`--hero-index: ${current}`">
          <template x-for="(slide, index) in slides" :key="index">
            <figure class="page-new__hero-slide">
              <div class="page-new__hero-mockup">
                <img
                  :src="slide.image"
                  alt=""
                  width="327"
                  height="674"
                  decoding="async"
                  class="page-new__hero-mockup-img"
                />
              </div>
              <figcaption class="page-new__hero-caption">
                <span class="page-new__hero-caption-num" x-text="`${index + 1}.`"></span>
                <span x-text="slide.caption"></span>
              </figcaption>
            </figure>
          </template>
        </div>
      </div>

      <div class="page-new__hero-pagination" role="tablist" aria-label="App preview screens">
        <template x-for="(slide, index) in slides" :key="index">
          <button
            type="button"
            class="page-new__hero-dot"
            :class="{ 'is-active': current === index }"
            :aria-selected="current === index"
            :aria-label="`Screen ${index + 1}: ${slide.caption}`"
            role="tab"
            @click="goTo(index)"
          ></button>
        </template>
      </div>
    </div>
  </div>
</section>

<section id="why" class="page-new__anchor page-new__anchor--why" aria-label="Why">
  <div class="page-new__why">
    <div class="page-new__why-card">
      <div class="page-new__why-content">
        <h2 class="page-new__why-title">“Now why would I do that?”</h2>

        <div class="page-new__why-prose">
          <p>
            Dialog Lab offers you a place to explore ideas and differences in a way that keeps you <strong>as safe as possible</strong> from abuse and long-term repercussions. This used to require expensive human facilitators to make it work — and even then peoples’ reputations were on the line.
          </p>
          <p>
            Dialog Lab’s proprietary AI model allows anyone to discuss topics <strong>without fear of abuse or personal attacks</strong>. Here’s how it works:
          </p>
        </div>

        <ol class="page-new__why-list">
          <li>The model introduces the conversation partners and topics, then model sits in the background and allows two people to discuss topics naturally through chat.</li>
          <li>When it sees abusive content, it blocks it from being sent in the first place and warns the aggressor.</li>
          <li>When it sees specific forms of debate behavior that is known to shut down conversation, it warns the users but allows the conversation to proceed.</li>
          <li>If the users get off-topic, the moderator nudges the participants back but doesn’t force the issue if users want to continue.</li>
        </ol>
      </div>
    </div>
  </div>
</section>

<section id="join-beta" class="page-new__anchor page-new__anchor--join" aria-label="Join the beta">
  <div class="page-new__signup">
    <div class="page-new__signup-intro">
      <h2 class="page-new__signup-headline">
        Sign-up, and <em>think for yourself</em>
      </h2>

      <div class="page-new__signup-prose">
        <p>
          We're recruiting a select group to be included in our beta app testing program. To be considered, you must be open to civil conversations via messaging with people who see things differently.
        </p>
        <p>
          Users will be anonymous to each other, and all information will be held confidential.
        </p>
      </div>
    </div>

    <div class="page-new__signup-form-wrap">
      <div class="page-new__signup-card">
        <form
          class="page-new__signup-form"
          x-data="{
            status: 'idle',
            errorMessage: '',
            async submit(event) {
              this.status = 'loading';
              this.errorMessage = '';
              const form = event.target;
              try {
                const res = await fetch(form.action, {
                  method: 'POST',
                  body: new FormData(form),
                  headers: { Accept: 'application/json' },
                });
                if (res.ok) {
                  this.status = 'success';
                  form.reset();
                } else {
                  const json = await res.json().catch(() => null);
                  this.errorMessage = json && json.errors
                    ? json.errors.map(e => e.message).join(', ')
                    : 'Something went wrong. Please try again.';
                  this.status = 'error';
                }
              } catch (e) {
                this.errorMessage = 'Something went wrong. Please check your connection and try again.';
                this.status = 'error';
              }
            }
          }"
          action="https://formspree.io/f/xdarwboa"
          method="POST"
          @submit.prevent="submit($event)"
        >
          <template x-if="status === 'success'">
            <p class="page-new__signup-message page-new__signup-message--success">
              Thank you for applying to join the beta. Please share this link with others that may be interested: joindialoglab.com
            </p>
          </template>

          <template x-if="status !== 'success'">
            <div class="page-new__signup-fields">
              <div class="page-new__signup-field">
                <label class="page-new__signup-label" for="signup-name">Your Name</label>
                <input
                  id="signup-name"
                  class="page-new__signup-input"
                  type="text"
                  name="name"
                  maxlength="128"
                  required
                  autocomplete="name"
                />
              </div>

              <div class="page-new__signup-field">
                <label class="page-new__signup-label" for="signup-email">Your Email</label>
                <input
                  id="signup-email"
                  class="page-new__signup-input"
                  type="email"
                  name="email"
                  maxlength="128"
                  required
                  autocomplete="email"
                />
              </div>

              <div class="page-new__signup-field">
                <label class="page-new__signup-label" for="signup-message">What you hope to get out of Dialog Lab</label>
                <textarea
                  id="signup-message"
                  class="page-new__signup-textarea"
                  name="message"
                  maxlength="16384"
                  required
                ></textarea>
              </div>

              <div class="page-new__signup-consent">
                <input
                  id="signup-consent"
                  class="page-new__signup-checkbox"
                  type="checkbox"
                  name="consent"
                  value="checked"
                  required
                />
                <label class="page-new__signup-consent-label" for="signup-consent">
                  I certify that I am 18 years or older.
                </label>
              </div>

              <template x-if="status === 'error'">
                <p class="page-new__signup-message page-new__signup-message--error" x-text="errorMessage"></p>
              </template>

              <div class="page-new__signup-submit-wrap">
                <button class="page-new__signup-submit" type="submit" :disabled="status === 'loading'">
                  <span x-show="status !== 'loading'">Join iOS Beta</span>
                  <span x-show="status === 'loading'">Sending…</span>
                </button>
              </div>
            </div>
          </template>
        </form>
      </div>
    </div>
  </div>

  <footer class="page-new__footer">
    <div class="page-new__footer-brand">
      <img
        class="page-new__footer-mark"
        src="{{ '/assets/images/footer-mark.svg' | url }}"
        alt=""
        width="126"
        height="101"
        decoding="async"
      />
      <p class="page-new__footer-wordmark">Dialog Lab</p>
    </div>
    <p class="page-new__footer-tagline">Agree to disagree.</p>
    <div class="page-new__footer-links">
      <p class="page-new__footer-year">2026</p>
      <a href="mailto:spencer@spencerfrank.com" class="page-new__footer-link">Questions?</a>
      <a
        href="https://www.youtube.com/watch?v=QmSXMpqlVIo"
        target="_blank"
        rel="noopener"
        aria-label="Watch on YouTube"
        class="page-new__footer-youtube"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814ZM9.545 15.568V8.432L15.818 12l-6.273 3.568Z"/>
        </svg>
      </a>
    </div>
  </footer>
</section>
