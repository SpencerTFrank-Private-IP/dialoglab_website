<body class="text-brand font-sans antialiased">
  <nav class="fixed top-0 inset-x-0 z-10 flex items-center gap-3 md:gap-6 py-3 md:py-4 px-4 md:px-6 bg-[#f5f5f5]/90 backdrop-blur-sm">
    <a href="#home" class="shrink-0">
      <img src="/assets/images/icon-master-iOS-Default-1024x1024@1x.png" alt="Dialog Lab" class="w-8 h-8 md:w-9 md:h-9 rounded-lg" />
    </a>
    <div class="flex flex-1 flex-wrap justify-center gap-x-3 gap-y-1 md:gap-x-6 md:gap-y-2 text-[0.8125em] md:text-[1.125em]">
      <a href="#why-dialog-lab" class="hover:underline">Why Dialog Lab</a>
      <a href="#how-it-works" class="hover:underline">How the App Works</a>
      <a href="#ai-moderation-principles" class="hover:underline">AI Moderation Principles</a>
    </div>
    <a href="#join-beta" class="shrink-0 rounded-full bg-brand text-white px-4 py-2 text-[0.75em] md:text-[1em] font-medium hover:bg-brand-dark transition-colors">Join the Beta</a>
  </nav>

  <div class="snap-y snap-mandatory h-screen overflow-y-scroll">
    <main class="flex flex-col items-center">
      {{ content | safe }}
    </main>
  </div>
</body>
</html>
