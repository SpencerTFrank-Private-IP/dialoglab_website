{
  "name": "dialoglab-11ty",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i ./tailwind/input.css -o ./src/assets/css/style.css --minify",
    "watch:css": "tailwindcss -i ./tailwind/input.css -o ./src/assets/css/style.css --watch",
    "build": "npm run build:css && eleventy",
    "serve": "npm run build:css && eleventy --serve",
    "dev": "concurrently \"npm:watch:css\" \"eleventy --serve\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@tailwindcss/cli": "^4.3.2",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2"
  },
  "private": true
}
